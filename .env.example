# ─── Database (Supabase PostgreSQL) ───────────────────────────────
# Use the "Connection string" → "URI" from Supabase dashboard.
# For Prisma, prefer the pooled connection (port 6543) + add ?pgbouncer=true
# and set DIRECT_URL to the direct connection (port 5432) for migrations.
DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres"

# ─── License signing (MUST match tools/keygen.js & KaemDocs desktop) ──
# This exact value is the HMAC secret used to sign/verify license keys.
# It MUST be identical in: this web app, tools/keygen.js, and the KaemDocs
# desktop app — otherwise keys generated here won't validate offline there.
# NOTE: in a real .env, escape the $ as \$ so dotenv-expand keeps it intact.
LICENSE_SECRET="Km#9xP2vL$nR7qW4@jD6eY1uB8sF3hZ5"
# LICENSE_HMAC_SECRET is an accepted alias for LICENSE_SECRET. If you set it,
# it MUST hold the same value. Only one of the two is required.
LICENSE_HMAC_SECRET="Km#9xP2vL$nR7qW4@jD6eY1uB8sF3hZ5"

# ─── Cloudflare R2 (S3-compatible) ────────────────────────────────
CLOUDFLARE_R2_BUCKET=""
CLOUDFLARE_R2_ENDPOINT=""
CLOUDFLARE_R2_ACCESS_KEY=""
CLOUDFLARE_R2_SECRET_KEY=""
# Optional public base URL if the bucket is served via a custom/public domain
CLOUDFLARE_R2_PUBLIC_URL="https://assets.kaemnur.com"

# ─── Admin panel (both required to log in) ────────────────────────
ADMIN_USERNAME="kaemnur"
ADMIN_PASSWORD="change-me-in-production"

# ─── WhatsApp upgrade funnel ──────────────────────────────────────
NEXT_PUBLIC_WHATSAPP_NUMBER="6282111990423"
