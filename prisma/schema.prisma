// Kaemnur Website Ecosystem — Prisma schema
// Postgres (Supabase). Pooled DATABASE_URL for the app, DIRECT_URL for migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Platform {
  WINDOWS
  MAC
  LINUX
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  tagline       String? // short one-liner for hero / cards
  description   String
  version       String
  category      String
  isFeatured    Boolean  @default(false)
  downloadCount Int      @default(0)
  priceFree      Boolean  @default(true)
  priceAmount    Int?     // in Rupiah, null = free-only
  priceLabel     String?  // e.g. "Rp 99.000" — admin-provided display string
  ratingOverride Float?   // admin-set override; if set, displayed instead of avg
  createdAt      DateTime @default(now())

  screenshots       ProductScreenshot[]
  features          ProductFeature[]
  changelogs        Changelog[]
  installers        Installer[]
  licenses          License[]
  downloadLogs      DownloadLog[]
  requirements      ProductRequirement[]
  mentionedInTopics Topic[]  @relation("TopicMentions")
  ratings           ProductRating[]

  @@index([category])
}

model ProductScreenshot {
  id        String  @id @default(cuid())
  productId String
  url       String
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductFeature {
  id        String  @id @default(cuid())
  productId String
  text      String
  isPro     Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Changelog {
  id         String   @id @default(cuid())
  productId  String
  version    String
  notes      String
  releasedAt DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Installer {
  id        String   @id @default(cuid())
  productId String
  version   String
  platform  Platform
  fileUrl   String
  fileSize  Int // bytes
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model License {
  id                String    @id @default(cuid())
  key               String    @unique
  productId         String
  buyerName         String
  buyerWhatsapp     String
  userId            String?   // linked Kaemnur account (set by admin) — shows in /account
  isActivated       Boolean   @default(false)
  activatedAt       DateTime?
  deviceId          String?   // hardware fingerprint bound at activation
  activatedPlatform String?   // "WINDOWS" or "MAC"
  resetAt           DateTime? // set when admin resets; distinguishes "Direset" from "Belum Diaktifkan"
  createdAt         DateTime  @default(now())
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  user              UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([key])
  @@index([deviceId])
  @@index([userId])
}

model DownloadLog {
  id        String      @id @default(cuid())
  productId String
  platform  Platform
  userId    String?     // Supabase auth user id (null for anonymous downloads)
  createdAt DateTime    @default(now())
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      UserProfile? @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([createdAt])
  @@index([userId])
}

model ProductRequirement {
  id        String  @id @default(cuid())
  productId String
  type      String  // "minimum" or "recommended"
  os        String?
  cpu       String?
  ram       String?
  disk      String?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─── Community ────────────────────────────────────────────────────────────

model Topic {
  id         String      @id @default(cuid())
  title      String
  body       String
  authorName String
  category   String      @default("General")
  isPinned   Boolean     @default(false) // admin-pinned; max 3, shown at top of community
  userId     String?     // Supabase auth user id (null for legacy/anonymous)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  comments          Comment[]
  mentionedProducts Product[]      @relation("TopicMentions")
  notifications     Notification[]
  user              UserProfile?   @relation(fields: [userId], references: [id])

  @@index([category])
  @@index([createdAt])
  @@index([userId])
}

model Comment {
  id         String      @id @default(cuid())
  topicId    String
  body       String
  authorName String
  isAdmin    Boolean     @default(false)
  userId     String?     // Supabase auth user id (null for legacy/anonymous)
  createdAt  DateTime    @default(now())
  topic      Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user       UserProfile? @relation(fields: [userId], references: [id])

  @@index([topicId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // 'new_topic' | 'new_comment' | 'product_mention'
  topicId   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  topic     Topic    @relation(fields: [topicId], references: [id], onDelete: Cascade)

  @@index([topicId])
  @@index([isRead])
  @@index([createdAt])
}

// ─── User Auth ────────────────────────────────────────────────────────────

model UserProfile {
  id          String   @id // Supabase auth UUID — must match auth.users.id
  displayName String?
  avatarUrl   String?
  email       String?
  createdAt   DateTime @default(now())

  topics       Topic[]
  comments     Comment[]
  ratings      ProductRating[]
  downloadLogs DownloadLog[]
  licenses     License[]
}

model ProductRating {
  id         String      @id @default(cuid())
  productId  String
  userId     String      // Supabase auth UUID
  rating     Int         // 1-5
  reviewText String?     // optional written review (max 500 chars)
  createdAt  DateTime    @default(now())
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId]) // one rating per user per product
  @@index([productId])
  @@index([userId])
}
