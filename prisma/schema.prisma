// Kaemnur Website Ecosystem — Prisma schema
// Postgres (Supabase). Pooled DATABASE_URL for the app, DIRECT_URL for migrations.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Platform {
  WINDOWS
  MAC
  LINUX
}

model Product {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  tagline       String? // short one-liner for hero / cards
  logoUrl       String? // product logo image (Cloudflare R2 assets); falls back to initial
  heroImageUrl  String? // transparent PNG/WEBP for the homepage hero (R2 assets)
  description   String
  version       String
  category      String
  isFeatured    Boolean  @default(false)
  downloadCount Int      @default(0)
  priceFree      Boolean  @default(true)
  priceAmount    Int?     // in Rupiah, null = free-only
  priceLabel     String?  // e.g. "Rp 99.000" — admin-provided display string
  ratingOverride Float?   // admin-set override; if set, displayed instead of avg
  createdAt      DateTime @default(now())

  screenshots       ProductScreenshot[]
  features          ProductFeature[]
  changelogs        Changelog[]
  installers        Installer[]
  licenses          License[]
  downloadLogs      DownloadLog[]
  requirements      ProductRequirement[]
  mentionedInTopics Topic[]  @relation("TopicMentions")
  ratings           ProductRating[]
  orders            Order[]

  @@index([category])
}

model ProductScreenshot {
  id        String  @id @default(cuid())
  productId String
  url       String
  order     Int     @default(0)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model ProductFeature {
  id        String  @id @default(cuid())
  productId String
  text      String
  isPro     Boolean @default(false)
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Changelog {
  id         String   @id @default(cuid())
  productId  String
  version    String
  notes      String
  releasedAt DateTime @default(now())
  product    Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

model Installer {
  id        String   @id @default(cuid())
  productId String
  version   String
  platform  Platform
  fileUrl   String
  fileSize  Int // bytes
  sha256    String // hex SHA-256 of the installer file; required for client integrity checks
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  downloadLogs DownloadLog[]

  @@index([productId])
  @@index([productId, platform, createdAt])
}

model License {
  id                String    @id @default(cuid())
  key               String    @unique
  productId         String
  buyerName         String
  buyerWhatsapp     String
  userId            String?   // linked Kaemnur account (set by admin) — shows in /account
  isActivated       Boolean   @default(false)
  activatedAt       DateTime?
  deviceId          String?   // hardware fingerprint bound at activation
  activatedPlatform String?   // "WINDOWS" or "MAC"
  resetAt           DateTime? // set when admin resets; distinguishes "Direset" from "Belum Diaktifkan"
  expiresAt         DateTime? // null = never expires; past date = expired license
  createdAt         DateTime  @default(now())
  product           Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  user              UserProfile? @relation(fields: [userId], references: [id], onDelete: SetNull)
  order             Order?

  @@index([productId])
  @@index([key])
  @@index([deviceId])
  @@index([userId])
}

model DownloadLog {
  id          String      @id @default(cuid())
  productId   String
  installerId String?     // which installer binary was served (null for legacy rows)
  platform    Platform
  userId      String?     // Supabase auth user id (null for anonymous downloads)
  userAgent   String?     // truncated UA string for basic analytics
  ipHash      String?     // salted SHA-256 of client IP — no raw IP stored
  createdAt   DateTime    @default(now())
  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  installer   Installer?  @relation(fields: [installerId], references: [id], onDelete: SetNull)
  user        UserProfile? @relation(fields: [userId], references: [id])

  @@index([productId])
  @@index([installerId])
  @@index([createdAt])
  @@index([userId])
}

model ProductRequirement {
  id        String  @id @default(cuid())
  productId String
  type      String  // "minimum" or "recommended"
  os        String?
  cpu       String?
  ram       String?
  disk      String?
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─── Community ────────────────────────────────────────────────────────────

model Topic {
  id         String      @id @default(cuid())
  title      String
  body       String
  authorName String
  category   String      @default("General")
  isPinned   Boolean     @default(false) // admin-pinned; max 3, shown at top of community
  userId     String?     // Supabase auth user id (null for legacy/anonymous)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  comments          Comment[]
  mentionedProducts Product[]      @relation("TopicMentions")
  notifications     Notification[]
  user              UserProfile?   @relation(fields: [userId], references: [id])

  @@index([category])
  @@index([createdAt])
  @@index([userId])
}

model Comment {
  id         String      @id @default(cuid())
  topicId    String
  body       String
  authorName String
  isAdmin    Boolean     @default(false)
  userId     String?     // Supabase auth user id (null for legacy/anonymous)
  createdAt  DateTime    @default(now())
  topic      Topic       @relation(fields: [topicId], references: [id], onDelete: Cascade)
  user       UserProfile? @relation(fields: [userId], references: [id])

  @@index([topicId])
  @@index([userId])
}

model Notification {
  id        String   @id @default(cuid())
  type      String   // 'new_topic' | 'new_comment' | 'product_mention' | 'new_order' | 'order_approved'
  topicId   String?
  orderId   String?
  userId    String?  // user-targeted notification (null = admin-facing)
  message   String
  link      String?  // optional URL the user notification points to
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  topic     Topic?   @relation(fields: [topicId], references: [id], onDelete: Cascade)
  order     Order?   @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([topicId])
  @@index([orderId])
  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// ─── User Auth ────────────────────────────────────────────────────────────

model UserProfile {
  id          String   @id // Supabase auth UUID — must match auth.users.id
  displayName String?
  avatarUrl   String?
  email       String?
  createdAt   DateTime @default(now())

  topics       Topic[]
  comments     Comment[]
  ratings      ProductRating[]
  downloadLogs DownloadLog[]
  licenses     License[]
  orders       Order[]
  appRequests     AppRequest[]
  appRequestVotes AppRequestVote[]
}

model ProductRating {
  id         String      @id @default(cuid())
  productId  String
  userId     String      // Supabase auth UUID
  rating     Int         // 1-5
  reviewText String?     // optional written review (max 500 chars)
  createdAt  DateTime    @default(now())
  product   Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      UserProfile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([productId, userId]) // one rating per user per product
  @@index([productId])
  @@index([userId])
}

// ─── Orders / Checkout ──────────────────────────────────────────────────────

enum OrderStatus {
  BELUM_BAYAR
  MENUNGGU_KONFIRMASI
  SUDAH_DIBAYAR
  DIBATALKAN
}

model Order {
  id            String      @id @default(cuid())
  orderNumber   String      @unique
  userId        String
  user          UserProfile @relation(fields: [userId], references: [id])
  productId     String
  product       Product     @relation(fields: [productId], references: [id])
  productName   String // snapshot at order time
  amount        Int // Rupiah
  customerName  String
  customerPhone String
  status        OrderStatus @default(BELUM_BAYAR)
  licenseId     String?     @unique
  license       License?    @relation(fields: [licenseId], references: [id])
  paidClickedAt DateTime?
  approvedAt    DateTime?
  approvedBy    String?
  notifications Notification[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([userId])
  @@index([productId])
  @@index([status])
}

model AppSettings {
  id            String   @id @default("singleton")
  qrisImageUrl  String?
  qrisName      String?
  adminWhatsapp String?
  trakteerUrl   String?
  updatedAt     DateTime @updatedAt
}

// ─── App Requests / Donations ───────────────────────────────────────────────

enum RequestStatus {
  OPEN
  PLANNED
  IN_PROGRESS
  RELEASED
  REJECTED
}

model AppRequest {
  id                String           @id @default(cuid())
  title             String
  description       String
  userId            String
  user              UserProfile      @relation(fields: [userId], references: [id])
  status            RequestStatus    @default(OPEN)
  votes             AppRequestVote[]
  voteCount         Int              @default(0)
  releasedProductId String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@index([userId])
  @@index([status])
}

model AppRequestVote {
  id           String      @id @default(cuid())
  appRequestId String
  appRequest   AppRequest  @relation(fields: [appRequestId], references: [id], onDelete: Cascade)
  userId       String
  user         UserProfile @relation(fields: [userId], references: [id])
  createdAt    DateTime    @default(now())

  @@unique([appRequestId, userId])
  @@index([userId])
}

model Donation {
  id         String   @id @default(cuid())
  donorName  String
  amount     Int
  message    String?
  isApproved Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@index([isApproved])
}
